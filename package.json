{
	"name": "@genvid/c3source",
	"version": "1.2.0",
	"description": "Typed interfaces and traversal/formatting utilities for reading and mutating Construct 3 project source files (layouts, layers, instances, event sheets) on disk.",
	"license": "MIT-0",
	"author": "Genvid Technologies, inc. <support@genvidtech.com>",
	"repository": {
		"type": "git",
		"url": "https://github.com/genvid-holdings/c3source.git"
	},
	"homepage": "https://github.com/genvid-holdings/c3source",
	"bugs": {
		"url": "https://github.com/genvid-holdings/c3source/issues"
	},
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"LICENSE",
		"README.md"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsc",
		"verify-package": "node scripts/verify-package.mjs",
		"prepack": "npm run build && npm run verify-package",
		"test": "mocha --timeout 5000 --import=tsx --require ./test/setup.ts 'test/**/*.test.ts' --exit",
		"lint": "eslint --ext .ts --max-warnings 0 src/ test/",
		"typecheck": "tsc -p tsconfig.test.json --noEmit"
	},
	"engines": {
		"node": ">=22"
	},
	"devDependencies": {
		"mocha": "^10.4.0",
		"chai": "^5.1.1",
		"@types/node": "^22.0.0",
		"@types/mocha": "^10.0.6",
		"@types/chai": "^4.3.16",
		"tsx": "^4.21.0",
		"typescript": "^5.4.5",
		"eslint": "^8.36.0",
		"@typescript-eslint/eslint-plugin": "^7.10.0",
		"@typescript-eslint/parser": "^7.10.0",
		"eslint-config-prettier": "^8.7.0"
	}
}
